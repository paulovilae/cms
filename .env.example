# Database Configuration
DATABASE_URI=file:./cms.db

# Payload CMS Configuration
PAYLOAD_SECRET=your-payload-secret-here
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Business Mode Configuration
# Options: intellitrade, salarium, latinos, all
BUSINESS_MODE=all

# Enabled Features (comma-separated)
# Available features: aiManagement, gamification, digitalPayments, analytics, notifications
ENABLED_FEATURES=aiManagement,gamification

# IntelliTrade Configuration
INTELLITRADE_API_KEY=your-intellitrade-api-key
INTELLITRADE_WEBHOOK_SECRET=your-webhook-secret

# Salarium Configuration
SALARIUM_API_KEY=your-salarium-api-key
SALARIUM_WEBHOOK_SECRET=your-webhook-secret

# Latinos Trading Bot System Configuration
BOT_MICROSERVICE_URL=http://localhost:8000
BOT_MICROSERVICE_WS_URL=ws://localhost:8000/ws/trades
BOT_MICROSERVICE_TIMEOUT=10000
BOT_MICROSERVICE_MAX_RETRIES=3
BOT_MICROSERVICE_RETRY_DELAY=2000
BOT_MICROSERVICE_DEBUG=false

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# External API Keys
OPENAI_API_KEY=your-openai-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Development Configuration
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Security
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Analytics (optional)
GOOGLE_ANALYTICS_ID=your-ga-id
MIXPANEL_TOKEN=your-mixpanel-token

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Cache Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Monitoring
SENTRY_DSN=your-sentry-dsn
HEALTH_CHECK_INTERVAL=30000
