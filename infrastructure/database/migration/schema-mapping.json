  "validationRuleMapping": {
    "minLength": {
      "type": "min_length",
      "errorMessage": "Input must be at least {value} characters"
    },
    "maxLength": {
      "type": "max_length",
      "errorMessage": "Input must be at most {value} characters"
    },
    "required": {
      "type": "required",
      "errorMessage": "This field is required"
    },
    "email": {
      "type": "email",
      "errorMessage": "Please enter a valid email address"
    },
    "url": {
      "type": "url",
      "errorMessage": "Please enter a valid URL"
    },
    "numeric": {
      "type": "numeric",
      "errorMessage": "Please enter a valid number"
    }
  },

  "defaultAiConfigValues": {
    "temperature": 0.7,
    "maxTokens": 1000,
    "topP": 1.0,
    "presencePenalty": 0.0,
    "frequencyPenalty": 0.0
  },

  "defaultWorkflowValues": {
    "enableCascade": true,
    "requireApproval": false,
    "maxConcurrentSections": 1
