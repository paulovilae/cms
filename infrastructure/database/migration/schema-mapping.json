    "responsibilities": "responsibilities",
    "requirements": "requirements",
    "qualifications": "qualifications",
    "benefits": "benefits",
    "custom": "custom"
  },

  "statusMapping": {
    "draft": "draft",
    "in-progress": "in-progress",
    "completed": "completed",
    "archived": "archived"
  },

  "businessUnitMapping": {
    "salarium": "salarium",
    "intellitrade": "intellitrade",
    "latinos": "latinos",
    "capacita": "capacita"
  },

  "generationTypeMapping": {
