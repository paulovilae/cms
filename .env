# Shared Configuration (used by all environments)
# Secrets and common settings

# Payload secret for encryption
PAYLOAD_SECRET=your-payload-secret-here

# Secret for cron jobs
CRON_SECRET=your-cron-secret-here

# Secret for preview
PREVIEW_SECRET=your-preview-secret-here

# Credentials for database seeding
SEED_EMAIL=test@test.com
SEED_PASSWORD=Test12345%

# Use mock AI for testing (set to 'true' to bypass real AI services)
USE_MOCK_AI=false

# Note: BUSINESS_MODE and NEXT_PUBLIC_SERVER_URL are set in:
# - .env.local (for local development)
# - docker-compose.yml (for Docker containers)
# - Deployment platform (for production)
